FROM dsegura97/nginx

RUN apt update && apt install -yq --no-install-recommends \
    curl \
    ca-certificates

# Instalar Node 20 (controlando versión)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt install -y nodejs \
    && npm install -g npm@latest

RUN mkdir -p /root/admin/nodenext
RUN mkdir -p /root/admin/nodenext/proyectos/iawprojects
WORKDIR /root/admin/nodenext
COPY ./proyectos/ppokenext/deploy/pokenext /root/admin/nodenext/proyectos/iawprojects

COPY ./dockerfiles/nodejsnext/admin/start.sh .
RUN chmod +x /root/admin/nodenext/start.sh

ENTRYPOINT [ "./start.sh" ]